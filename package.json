{
  "name": "campus-event-ticketing",
  "version": "1.0.0",
  "private": true,
  "description": "Campus Event Management & Ticketing System monorepo",
  "workspaces": [
    "backend",
    "web",
    "mobile",
    "shared"
  ],
  "scripts": {
    "dev:db": "npm --workspace backend run dev:db",
    "dev:backend": "npm --workspace backend run dev",
    "dev:web": "npm --workspace web run dev",
    "dev:mobile": "npm --workspace mobile run start",
    "seed": "npm --workspace backend run seed",
    "build:backend": "npm --workspace backend run build",
    "build:web": "npm --workspace web run build"
  }
}
